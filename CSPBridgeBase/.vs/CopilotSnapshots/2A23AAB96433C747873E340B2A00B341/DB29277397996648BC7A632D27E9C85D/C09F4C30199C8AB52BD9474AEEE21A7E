#pragma once

#include <Windows.h>
#include <string>

/// <summary>
/// BridgeBaseクラス
/// </summary>
class BridgeBase
{
public:
    BridgeBase();
    virtual ~BridgeBase();

public:
    bool Initialize(TriglavPlugInServer* pluginServer);
    void Terminate(TriglavPlugInServer* pluginServer, TriglavPlugInPtr* data);

    // Invoke the managed entry point (if loaded). The argument is passed to managed method as a void* and
    // the managed method must be exported with UnmanagedCallersOnly and a compatible signature, for example:
    // [UnmanagedCallersOnly(EntryPoint = "Invoke")]
    // public static int Invoke(IntPtr args) { ... }
    int InvokeManaged(void* args);

private:
    // hostfxr library handle
    HMODULE hostfxr_lib_;
    // host context returned by hostfxr_initialize_for_runtime_config
    void* hostfxr_handle_;

    // delegate to load managed function
    void* load_assembly_and_get_function_pointer_delegate_;

    // pointer to the managed function obtained from the managed assembly
    void* managed_function_ptr_;

    // stored paths / names
    std::wstring managed_assembly_path_;
    std::wstring managed_type_name_;
    std::wstring managed_method_name_;

};
