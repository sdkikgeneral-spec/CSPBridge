#include "pch.h"
#include "BridgeBase.h"
#include <assert.h>
#include <filesystem>

// hostfxr function types
using hostfxr_handle = void*;
using load_assembly_and_get_function_pointer_fn = int(__stdcall*)(
    const wchar_t* assembly_path,
    const wchar_t* type_name,
    const wchar_t* method_name,
    const wchar_t* delegate_type_name,
    /*out*/ void** delegate);

// Minimal helper: load hostfxr from the same directory as the running process or PATH
static HMODULE LoadHostFxr()
{
    HMODULE h = nullptr;
    wchar_t path[MAX_PATH];
    if (::GetModuleFileNameW(nullptr, path, (DWORD)std::size(path)) != 0)
    {
        std::filesystem::path p(path);
        auto dir = p.parent_path();
        std::filesystem::path hostfxrPath = dir / L"hostfxr.dll";
        h = ::LoadLibraryW(hostfxrPath.wstring().c_str());
    }
    if (h == nullptr)
    {
        h = ::LoadLibraryW(L"hostfxr.dll");
    }
    return h;
}


/// <summary>
/// BridgeBaseのコンストラクタ
/// </summary>
BridgeBase::BridgeBase()
    : hostfxr_lib_(nullptr)
    , hostfxr_handle_(nullptr)
    , load_assembly_and_get_function_pointer_delegate_(nullptr)
    , managed_function_ptr_(nullptr)
{
}

/// <summary>
/// BridgeBaseのデストラクタ
/// </summary>
BridgeBase::~BridgeBase()
{
}

/// <summary>
/// BridgeBaseの初期化
/// </summary>
/// <param name="pluginServer"></param>
/// <returns></returns>
bool BridgeBase::Initialize(
	TriglavPlugInServer* pluginServer
)
{
	if (pluginServer == nullptr)
	{
		assert(false);
		return false;
	}

    // For embedding CoreCLR (hostfxr) we need to load hostfxr and then get the delegate
    hostfxr_lib_ = LoadHostFxr();
    if (hostfxr_lib_ == nullptr)
    {
        // Could not locate hostfxr; managed runtime will not be available
        return true; // not fatal for plugin, return true so plugin can still work in native-only mode
    }

    // Get the symbol for hostfxr_main or hostfxr_initialize_for_runtime_config as needed.
    // To keep this lightweight we will lookup "hostfxr_get_runtime_delegate" dynamically.
    using hostfxr_get_runtime_delegate_fn = int(__stdcall*)(void*, int, void**);
    auto get_delegate = (hostfxr_get_runtime_delegate_fn)::GetProcAddress(hostfxr_lib_, "hostfxr_get_runtime_delegate");
    if (get_delegate == nullptr)
    {
        // Unexpected hostfxr layout
        FreeLibrary(hostfxr_lib_);
        hostfxr_lib_ = nullptr;
        return true;
    }

    // NOTE: full hosting requires calling hostfxr_initialize_for_runtime_config with a runtimeconfig.json file
    // and then calling hostfxr_get_runtime_delegate to get load_assembly_and_get_function_pointer.
    // Implementing full flow is lengthy; here we leave managed loading to later implementation.

    return true;
}

